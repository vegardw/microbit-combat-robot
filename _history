n.P1, 0)\n            pins.servoWritePin(AnalogPin.P2, 0)\n        }\n        else if (direction == BotDirection.Right) {\n            pins.servoWritePin(AnalogPin.P1, 180)\n            pins.servoWritePin(AnalogPin.P2, 180)\n        }\n\n        if(duration > 0) {\n            basic.pause(duration)\n            pins.servoWritePin(AnalogPin.P1, 90)\n            pins.servoWritePin(AnalogPin.P2, 90)\n        }\n    }\n\n    /**\n     * Stop the bot\n     */\n    //% block\n    export function stop(): void {\n        pins.servoWritePin(AnalogPin.P1, 90)\n        pins.servoWritePin(AnalogPin.P2, 90)\n    }\n\n}\n"}]},{"timestamp":1775999073220,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":6339,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"device_button_event\" x=\"291\" y=\"-37\"><field name=\"NAME\">Button.A</field><statement name=\"HANDLER\"><block type=\"bot_stop\"></block></statement></block><block type=\"device_button_event\" x=\"0\" y=\"0\"><field name=\"NAME\">Button.B</field><statement name=\"HANDLER\"><block type=\"bot_drive\"><field name=\"direction\">BotDirection.Forward</field><value name=\"duration\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value></block></statement></block><block type=\"device_forever\" x=\"-12\" y=\"280\"></block></xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":487,"diffs":[[1,"input.onButtonPressed(Button.A, function () {\n    bot.stop()\n"]]},{"start1":64,"length1":161,"diffs":[[1,"input.onButtonPressed(Button.B, function () {\n    bot.drive(BotDirection.Forward, 0)\n"]]},{"start1":152,"length1":0,"diffs":[[1,"basic.forever(function () {\n\t\n})\n"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":2,"length1":28,"diffs":[[1,"    \"name\": \"combat bot\",\n"]]}]},{"type":"edited","filename":"bot.ts","patch":[{"start1":123,"length1":0,"diffs":[[