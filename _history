itePin(AnalogPin.P2, 90)\n    }\n\n}\n","pxt.json":"{\n    \"name\": \"combat robot\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"bot.ts\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}},{"timestamp":1776266285866,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"A#By:4!m.zmJ);3Dm#`3\">counter</variable></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block></xml>","main.ts":"radio.onReceivedValue(function (name, value) {\n    counter = 0\n    if (name == \"drive\") {\n        if (value == 0) {\n            bot.stop()\n        } else if (value == 1) {\n            bot.drive(bot.BotDirection.Forward, 0)\n        } else if (value == 2) {\n            bot.drive(bot.BotDirection.Backward, 0)\n        } else if (value == 3) {\n            bot.drive(bot.BotDirection.Left, 0)\n        } else if (value == 4) {\n            bot.drive(bot.BotDirection.Right, 0)\n        }\n    }\n})\nlet counter = 0\nbot.stop()\nradio.setGroup(1)\ncounter = 0\nbot.arm()\nloops.everyInterval(100, function () {\n    counter += 1\n    if (counter > 5) {\n        bot.stop()\n    }\n})\n\n","README.md":"","bot.ts":"namespace bot {\r\n    enum BotDirection {\r\n        Forward = 1,\r\n        Backward,\r\n        Left,\r\n        Right,\r\n    }\r\n}","pxt.json":"{\n    \"name\": \"combat robot\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"bot.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1776323212487,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developer