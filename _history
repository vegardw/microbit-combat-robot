(AnalogPin.P1, 90)\n        pins.servoWritePin(AnalogPin.P2, 90)\n    }\n\n}\n"]]}]}]},{"timestamp":1776260292741,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"bot.ts","patch":[{"start1":64,"length1":19,"diffs":[[1,"        Backward\r\n"]]}]}]},{"timestamp":1776260293752,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"bot.ts","patch":[{"start1":83,"length1":31,"diffs":[[1,""]]}]}]},{"timestamp":1776260304083,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":0,"diffs":[[1,"radio.onReceivedValue(function (name, value) {\n    counter = 0\n    if (name == \"drive\") {\n        if (value == 0) {\n            bot.stop()\n        } else if (value == 1) {\n            bot.drive(bot.BotDirection.Forward, 0)\n        } else if (value == 2) {\n            bot.drive(bot.BotDirection.Backward, 0)\n        } else if (value == 3) {\n            bot.drive(bot.BotDirection.Left, 0)\n        } else if (value == 4) {\n            bot.drive(bot.BotDirection.Right, 0)\n        }\n    }\n})\nlet counter = 0\nbot.stop()\nradio.setGroup(1)\ncounter = 0\nbot.arm()\nloops.everyInterval(100, function () {\n    counter += 1\n    if (counter > 5) {\n        bot.stop()\n    }\n})\n\n"]]}]}]},{"timestamp":1776266285866,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"pxt.json","patch":[{"start1":208,"length1":20,"diffs":[[1,"        \"README.md\",\n        \"bot.ts\"\n"]]}]},{"type":"removed","filename":"bot.ts","value":"namespace bot {\r\n    enum BotDirection {\r\n        Forward = 1,\r\n        Backward,\r\n        Left,\r\n        Right,\r\n    }\r\n}"}]},{"timestamp":1776266290973,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"pxt.json","patch":[{"start1":208,"length1":38,"diffs":[[1,"        \"README.md\"\n"]]}]},{"type":"added","filename":"bot.ts","value":"\n/**\n* Use this file to define custom functions and blocks.\n* Read more at https://makecode.microbit.org/bloc